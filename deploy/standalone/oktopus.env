# Oktopus standalone environment configuration.
# Override these values by mounting your own file at /etc/oktopus/oktopus.env
# or by passing --env-file to docker run.

# NATS
NATS_URL=nats://oktopususer:oktopuspw@localhost:4222
NATS_ENABLE_TLS=true
CLIENT_CRT=/etc/nats/cert.pem
CLIENT_KEY=/etc/nats/key.pem
SERVER_CA=/etc/nats/rootCA.pem

# WebSocket adapter — points to the ws service on localhost
WS_ADDR=localhost

# MongoDB
MONGO_URI=mongodb://localhost:27017

# TaaS
TAAS_PORT=8001
SECRET_API_KEY=supersecretkey
TAAS_CORS=*

# Default admin account seeded on first boot.
# Override by mounting your own /etc/oktopus/oktopus.env or via --env-file.
ADMIN_EMAIL=demo@gmail.com
ADMIN_NAME=Demo
ADMIN_PASSWORD=standalone
