[Unit]
Description=NATS Message Broker
After=network.target

[Service]
ExecStart=/usr/local/bin/nats-server \
    -c /etc/nats/nats.cfg
Restart=on-failure
RestartSec=3
Environment=NATS_NAME=oktopus
Environment=NATS_USER=oktopususer
Environment=NATS_PW=oktopuspw
RuntimeDirectory=nats
StateDirectory=nats

[Install]
WantedBy=multi-user.target
